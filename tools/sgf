#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_NAME="$(basename "$0")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
SGF_LIB_ROOT="$(readlink -f "$SCRIPT_DIR/..")"
SGF_LIB_PARENT="$(dirname "$SGF_LIB_ROOT")"

SUPPORTED_BOARDS=(unoq esp32)

die() {
  printf 'sgf: %s\n' "$*" >&2
  exit 1
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

basename_or_self() {
  local path="$1"
  if [ -z "$path" ]; then
    printf '%s' "$path"
    return
  fi
  printf '%s' "${path##*/}"
}

dirname_or_self() {
  local path="$1"
  if [ -z "$path" ]; then
    printf '%s' "$path"
    return
  fi
  if [[ "$path" != */* ]]; then
    printf '.'
    return
  fi
  printf '%s' "${path%/*}"
}

extract_command_source() {
  local line="$1"
  local token
  local previous=''

  for token in $line; do
    if [ "$previous" = "-o" ]; then
      break
    fi
    case "$token" in
      *.ino|*.c|*.cc|*.cpp|*.cxx|*.S)
        printf '%s' "$token"
        return
        ;;
    esac
    previous="$token"
  done
}

extract_link_output() {
  local line="$1"
  local token
  local previous=''

  for token in $line; do
    if [ "$previous" = "-o" ]; then
      printf '%s' "$token"
      return
    fi
    previous="$token"
  done
}

source_label() {
  local src="$1"
  local dir

  case "$src" in
    */build/*/sketch/*)
      printf '%s' "$(basename_or_self "$src")"
      return
      ;;
    "$SGF_LIB_ROOT"/src/SGF/*)
      printf 'SGF/%s' "$(basename_or_self "$src")"
      return
      ;;
    "$SGF_LIB_PARENT"/sgf-esp32/src/SGF/*)
      printf 'sgf-esp32/%s' "$(basename_or_self "$src")"
      return
      ;;
    "$SGF_LIB_PARENT"/sgf-hardware-presets/*)
      dir="$(basename_or_self "$(dirname_or_self "$src")")"
      printf 'sgf-hardware-presets/%s/%s' "$dir" "$(basename_or_self "$src")"
      return
      ;;
    "$PWD"/libraries/SGF/src/SGF/*)
      printf 'SGF/%s' "$(basename_or_self "$src")"
      return
      ;;
    "$PWD"/libraries/sgf-esp32/src/SGF/*)
      printf 'sgf-esp32/%s' "$(basename_or_self "$src")"
      return
      ;;
    "$PWD"/libraries/sgf-hardware-presets/*)
      dir="$(basename_or_self "$(dirname_or_self "$src")")"
      printf 'sgf-hardware-presets/%s/%s' "$dir" "$(basename_or_self "$src")"
      return
      ;;
    */build/*/libraries/SGF/SGF/*)
      printf 'SGF/%s' "$(basename_or_self "$src")"
      return
      ;;
    */build/*/libraries/sgf-esp32/SGF/*)
      printf 'sgf-esp32/%s' "$(basename_or_self "$src")"
      return
      ;;
    */build/*/libraries/sgf-hardware-presets/*)
      dir="$(basename_or_self "$(dirname_or_self "$src")")"
      printf 'sgf-hardware-presets/%s/%s' "$dir" "$(basename_or_self "$src")"
      return
      ;;
    */build/*/libraries/*)
      dir="$(basename_or_self "$(dirname_or_self "$src")")"
      printf '%s/%s' "$dir" "$(basename_or_self "$src")"
      return
      ;;
    *)
      printf '%s' "$(basename_or_self "$src")"
      return
      ;;
  esac
}

is_local_compile_source() {
  local src="$1"
  case "$src" in
    */build/*/sketch/*|*/build/*/libraries/SGF/*|*/build/*/libraries/sgf-esp32/*|*/build/*/libraries/sgf-hardware-presets/*|"$SGF_LIB_ROOT"/*|"$SGF_LIB_PARENT"/sgf-esp32/*|"$SGF_LIB_PARENT"/sgf-hardware-presets/*|"$PWD"/libraries/SGF/*|"$PWD"/libraries/sgf-esp32/*|"$PWD"/libraries/sgf-hardware-presets/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

emit_pretty_line() {
  local line="$1"
  local src
  local out
  local label

  case "$line" in
    *" -E -CC "*)
      printf '[PREP] Resolving includes...\n'
      return 0
      ;;
    *" -MMD -c "*)
      src="$(extract_command_source "$line")"
      if ! is_local_compile_source "$src"; then
        printf '[CORE] Compiling Arduino core and external libraries...\n'
        return 0
      fi
      label="$(source_label "$src")"
      if [[ "$line" == *"g++ -MMD -c "* ]]; then
        printf '[CXX] %s\n' "$label"
      else
        printf '[CC] %s\n' "$label"
      fi
      return 0
      ;;
    *" ar "*".a "*|*"gcc-ar "*".a "*)
      return 0
      ;;
    *"g++ "*".elf"*|*"gcc "*".elf"*|*"ld "*".elf"*)
      out="$(extract_link_output "$line")"
      printf '[LD] %s\n' "$(basename_or_self "$out")"
      return 0
      ;;
    "Detecting libraries used..."*)
      printf '[DEPS] Detecting libraries used...\n'
      return 0
      ;;
    "Using board "*)
      printf '[CFG] %s\n' "$line"
      return 0
      ;;
    "Using core "*)
      printf '[CFG] %s\n' "$line"
      return 0
      ;;
    "FQBN: "*)
      printf '[CFG] %s\n' "$line"
      return 0
      ;;
    "Sketch uses "*|"Global variables use "*)
      printf '%s\n' "$line"
      return 0
      ;;
    "esptool v"*|"Creating ESP32 image..."|"Merged "*|"Successfully created ESP32 image."*)
      printf '[IMG] %s\n' "$line"
      return 0
      ;;
    "Alternatives for "*|"ResolveLibrary("*|"  -> candidates:"*)
      return 0
      ;;
    *"bash -c "*)
      return 0
      ;;
    "loading library from "*)
      printf '[WARN] %s\n' "$line"
      return 0
      ;;
    *": error: "*|*": fatal error: "*|*": warning: "*|*": note: "*)
      printf '%s\n' "$line"
      return 0
      ;;
    "Error during build:"*)
      printf '%s\n' "$line"
      return 0
      ;;
  esac

  return 0
}

run_arduino_cli() {
  local cli="$1"
  shift
  local line
  local cmd_status
  local emitted_prep=0
  local emitted_core=0
  local src

  if [ "$CLI_VERBOSE" -eq 1 ]; then
    "$cli" "$@"
    return
  fi

  if [ "$CLI_QUIET" -eq 1 ]; then
    local output
    set +e
    output="$("$cli" "$@" 2>&1)"
    cmd_status=$?
    set -e
    if [ "$cmd_status" -ne 0 ]; then
      printf '%s\n' "$output"
    fi
    return "$cmd_status"
  fi

  set +e
  "$cli" "$@" 2>&1 | while IFS= read -r line; do
    case "$line" in
      *" -E -CC "*)
        if [ "$emitted_prep" -eq 0 ]; then
          emit_pretty_line "$line"
          emitted_prep=1
        fi
        ;;
      *" -MMD -c "*)
        src="$(extract_command_source "$line")"
        if is_local_compile_source "$src"; then
          emit_pretty_line "$line"
        else
          if [ "$emitted_core" -eq 0 ]; then
            emit_pretty_line "$line"
            emitted_core=1
          fi
        fi
        ;;
      *)
        emit_pretty_line "$line"
        ;;
    esac
  done
  cmd_status=${PIPESTATUS[0]}
  set -e
  return "$cmd_status"
}

usage() {
  cat <<EOF
Usage:
  $SCRIPT_NAME init [target_dir] [--name PROJECT_NAME] [--force]
  $SCRIPT_NAME build [board=NAME] [port=/dev/ttyXXX] [monitor_config=115200] [arduino_ide=/path] [--clean-build] [-v|--verbose] [-q|--quiet]
  $SCRIPT_NAME elfinfo [board=NAME] [port=/dev/ttyXXX] [monitor_config=115200] [arduino_ide=/path] [--build] [--clean-build] [-v|--verbose] [-q|--quiet] [--units b|kb|mb|auto]
  $SCRIPT_NAME gentextures [--src DIR] [--out BASENAME]
  $SCRIPT_NAME gensamples [--src DIR] [--out BASENAME]
  $SCRIPT_NAME flash [board=NAME] [port=/dev/ttyXXX] [arduino_ide=/path] [--clean-build] [-v|--verbose] [-q|--quiet]
  $SCRIPT_NAME upload [board=NAME] [port=/dev/ttyXXX] [arduino_ide=/path] [-v|--verbose] [-q|--quiet]
  $SCRIPT_NAME monitor [board=NAME] [port=/dev/ttyXXX] [monitor_config=115200] [arduino_ide=/path]
  $SCRIPT_NAME boards
  $SCRIPT_NAME info [board=NAME] [arduino_ide=/path]
  $SCRIPT_NAME clean [board=NAME]

Metadata lives in the sketch entrypoint as comment lines:
  // sgf.name: MyGame
  // sgf.boards: unoq, esp32
  // sgf.default_board: unoq
  // sgf.port.unoq: /dev/ttyACM0
  // sgf.port.esp32: /dev/ttyUSB0

Optional local Arduino libraries:
  ./libraries/SGF
  ./libraries/sgf-hardware-presets

Examples:
  $SCRIPT_NAME init .
  $SCRIPT_NAME build board=esp32
  $SCRIPT_NAME build -v board=esp32
  $SCRIPT_NAME build -q board=esp32
  $SCRIPT_NAME build --clean-build board=esp32
  $SCRIPT_NAME elfinfo -q --units kb board=esp32
  $SCRIPT_NAME elfinfo --build --clean-build board=esp32
  $SCRIPT_NAME gentextures
  $SCRIPT_NAME gensamples --src alt-samples --out MySamplesGenerated
  DEFINES="APP_FEATURE=1 APP_WIDTH=200 APP_HEIGHT=140" $SCRIPT_NAME build board=esp32
  EXTRA_FLAGS="-DAPP_FEATURE=1 -DAPP_WIDTH=200 -DAPP_HEIGHT=140" $SCRIPT_NAME build board=esp32
  $SCRIPT_NAME build arduino_ide=/opt/arduino-ide board=esp32
  $SCRIPT_NAME flash board=esp32 port=/dev/ttyUSB0
  $SCRIPT_NAME upload board=esp32 port=/dev/ttyUSB0
EOF
}

sanitize_class_name() {
  local input="$1"
  local part
  local out=""

  while IFS= read -r part; do
    [ -n "$part" ] || continue
    out+="${part^}"
  done < <(printf '%s' "$input" | tr -cs '[:alnum:]' '\n')

  if [ -z "$out" ]; then
    out="App"
  fi

  if [[ "$out" =~ ^[0-9] ]]; then
    out="App$out"
  fi

  printf '%s' "$out"
}

board_default_fqbn() {
  case "$1" in
    unoq) printf '%s' 'arduino:zephyr:unoq' ;;
    esp32) printf '%s' 'esp32:esp32:esp32' ;;
    *) die "unsupported board '$1'. Supported values: ${SUPPORTED_BOARDS[*]}" ;;
  esac
}

board_default_options() {
  case "$1" in
    unoq) printf '%s' 'link_mode=dynamic,flash_mode=flash,wait_linux_boot=yes' ;;
    esp32) printf '%s' 'UploadSpeed=921600,CPUFreq=240,FlashFreq=80,FlashMode=qio,FlashSize=4M,PartitionScheme=default,DebugLevel=none,PSRAM=disabled,LoopCore=1,EventsCore=1,EraseFlash=none,JTAGAdapter=default,ZigbeeMode=default' ;;
    *) die "unsupported board '$1'. Supported values: ${SUPPORTED_BOARDS[*]}" ;;
  esac
}

board_default_preset() {
  case "$1" in
    unoq) printf '%s' 'SGF_HW_PRESET_UNOQ_ILI9341_320X240' ;;
    esp32) printf '%s' 'SGF_HW_PRESET_ESP32_ST7789_240X240' ;;
    *) die "unsupported board '$1'. Supported values: ${SUPPORTED_BOARDS[*]}" ;;
  esac
}

board_default_port() {
  case "$1" in
    unoq) printf '%s' '/dev/ttyACM0' ;;
    esp32) printf '%s' '/dev/ttyUSB0' ;;
    *) die "unsupported board '$1'. Supported values: ${SUPPORTED_BOARDS[*]}" ;;
  esac
}

metadata_get() {
  local file="$1"
  local key="$2"
  local value

  value="$(
    awk -v key="$key" '
      {
        if (match($0, /^[[:space:]]*\/\/[[:space:]]*sgf\.([[:alnum:]_.-]+)[[:space:]]*:[[:space:]]*(.*)$/, matchData)) {
          if (matchData[1] == key) {
            print matchData[2]
            exit
          }
        }
      }
    ' "$file"
  )"

  value="$(trim "$value")"
  [ -n "$value" ] || return 1
  printf '%s' "$value"
}

split_csv() {
  local csv="$1"
  local item
  local old_ifs="$IFS"
  IFS=','
  for item in $csv; do
    item="$(trim "$item")"
    [ -n "$item" ] && printf '%s\n' "$item"
  done
  IFS="$old_ifs"
}

find_arduino_cli() {
  local cli
  local candidate
  local ide_dir="${CLI_ARDUINO_IDE:-}"

  if [ -n "$ide_dir" ]; then
    candidate="$ide_dir/resources/app/lib/backend/resources/arduino-cli"
    [ -x "$candidate" ] || die "arduino-cli not found under arduino-ide path: $ide_dir"
    printf '%s' "$candidate"
    return
  fi

  cli="$(command -v arduino-cli 2>/dev/null || true)"
  if [ -n "$cli" ]; then
    printf '%s' "$cli"
    return
  fi

  for candidate in \
    /opt/arduino-ide/resources/app/lib/backend/resources/arduino-cli \
    /usr/local/bin/arduino-cli \
    /usr/bin/arduino-cli; do
    if [ -x "$candidate" ]; then
      printf '%s' "$candidate"
      return
    fi
  done

  die "arduino-cli not found; set PATH or pass --arduino-ide /path/to/arduino-ide"
}

discover_entrypoint() {
  local dir_basename
  local file
  local annotated=()
  local inos=()

  shopt -s nullglob
  for file in *.ino; do
    inos+=("$file")
  done
  shopt -u nullglob

  [ "${#inos[@]}" -gt 0 ] || die "no .ino entrypoint found in $(pwd)"

  if [ "${#inos[@]}" -eq 1 ]; then
    printf '%s' "${inos[0]}"
    return
  fi

  dir_basename="$(basename "$PWD").ino"
  if [ -f "$dir_basename" ]; then
    printf '%s' "$dir_basename"
    return
  fi

  for file in "${inos[@]}"; do
    if metadata_get "$file" 'name' >/dev/null 2>&1; then
      annotated+=("$file")
    fi
  done

  if [ "${#annotated[@]}" -eq 1 ]; then
    printf '%s' "${annotated[0]}"
    return
  fi

  die "multiple .ino files found; keep one entrypoint or name one $(basename "$PWD").ino"
}

array_contains() {
  local needle="$1"
  shift
  local item

  for item in "$@"; do
    if [ "$item" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

ENTRYPOINT=''
SKETCH_NAME=''
DEFAULT_BOARD=''
PROJECT_BOARDS=()
PROJECT_EXTRA_FLAGS=''
PROJECT_MONITOR_CONFIG=''

load_project_context() {
  local configured_name
  local default_board

  if [ -n "$ENTRYPOINT" ]; then
    return
  fi

  ENTRYPOINT="$(discover_entrypoint)"
  configured_name="$(metadata_get "$ENTRYPOINT" 'name' || true)"
  if [ -n "$configured_name" ]; then
    SKETCH_NAME="$configured_name"
  else
    SKETCH_NAME="${ENTRYPOINT%.ino}"
  fi

  if metadata_get "$ENTRYPOINT" 'boards' >/dev/null 2>&1; then
    mapfile -t PROJECT_BOARDS < <(split_csv "$(metadata_get "$ENTRYPOINT" 'boards')")
  else
    PROJECT_BOARDS=("${SUPPORTED_BOARDS[@]}")
  fi

  [ "${#PROJECT_BOARDS[@]}" -gt 0 ] || die "no boards configured in $ENTRYPOINT"

  default_board="$(metadata_get "$ENTRYPOINT" 'default_board' || true)"
  if [ -n "$default_board" ]; then
    DEFAULT_BOARD="$default_board"
  else
    DEFAULT_BOARD="${PROJECT_BOARDS[0]}"
  fi

  array_contains "$DEFAULT_BOARD" "${PROJECT_BOARDS[@]}" || \
    die "default board '$DEFAULT_BOARD' is not listed in sgf.boards"

  PROJECT_EXTRA_FLAGS="$(metadata_get "$ENTRYPOINT" 'extra_flags' || true)"
  PROJECT_MONITOR_CONFIG="$(metadata_get "$ENTRYPOINT" 'monitor_config' || true)"
}

resolve_board_value() {
  local entrypoint="$1"
  local board="$2"
  local key="$3"
  local value

  value="$(metadata_get "$entrypoint" "$key.$board" || true)"
  if [ -n "$value" ]; then
    printf '%s' "$value"
    return
  fi

  case "$key" in
    fqbn) board_default_fqbn "$board" ;;
    options) board_default_options "$board" ;;
    preset) board_default_preset "$board" ;;
    port) board_default_port "$board" ;;
    *) die "unsupported board metadata key '$key'" ;;
  esac
}

resolve_env_extra_flags() {
  local name
  local value
  local extra_flags=''
  local spi_freq_hz
  local define
  local defines_value="${DEFINES:-}"
  local extra_flags_value="${EXTRA_FLAGS:-}"

  if [ -n "$defines_value" ]; then
    defines_value="${defines_value//,/ }"
    for define in $defines_value; do
      case "$define" in
        *=*)
          extra_flags="$extra_flags -D$define"
          ;;
        *)
          extra_flags="$extra_flags -D$define=1"
          ;;
      esac
    done
  fi

  if [ -n "$extra_flags_value" ]; then
    extra_flags="$extra_flags $extra_flags_value"
  fi

  while IFS='=' read -r name value; do
    case "$name" in
      DEFINES|EXTRA_FLAGS)
        ;;
      ENABLE_[A-Z0-9_]*)
        if [ -z "$value" ]; then
          value=1
        fi
        extra_flags="$extra_flags -D$name=$value"
        ;;
      PHYSICS_TARGET_FPS|RENDER_TARGET_FPS)
        extra_flags="$extra_flags -D$name=$value"
        ;;
      SPI_FREQ)
        [ -n "$value" ] || continue
        [[ "$value" =~ ^[0-9]+$ ]] || die "SPI_FREQ must be an integer in MHz or Hz"
        spi_freq_hz="$value"
        if [ "$spi_freq_hz" -lt 1000 ]; then
          spi_freq_hz=$((spi_freq_hz * 1000000))
        fi
        extra_flags="$extra_flags -DSGF_ESP32_ST7789_240X240_SPI_HZ=${spi_freq_hz}u"
        ;;
      DMA_BUS)
        [ -n "$value" ] || value=1
        [[ "$value" =~ ^[01]$ ]] || die "DMA_BUS must be 0 or 1"
        extra_flags="$extra_flags -DSGF_ESP32_ST7789_240X240_USE_DMA_BUS=$value"
        ;;
    esac
  done < <(env)

  extra_flags="$(trim "$extra_flags")"
  printf '%s' "$extra_flags"
}

resolve_build_extra_flags() {
  local preset="$1"
  local extra_flags='-DSGF_HW_PRESET='"$preset"
  local env_extra_flags

  if [ -n "$PROJECT_EXTRA_FLAGS" ]; then
    extra_flags="$extra_flags $PROJECT_EXTRA_FLAGS"
  fi

  env_extra_flags="$(resolve_env_extra_flags)"
  if [ -n "$env_extra_flags" ]; then
    extra_flags="$extra_flags $env_extra_flags"
  fi

  printf '%s' "$extra_flags"
}

CLI_BOARD=''
CLI_PORT=''
CLI_MONITOR_CONFIG=''
CLI_ARDUINO_IDE=''
CLI_CLEAN_BUILD=0
CLI_BUILD=0
CLI_VERBOSE=0
CLI_QUIET=0
CLI_UNITS='auto'
CLI_ARGS=()
GEN_SRC_DIR=''
GEN_OUT_BASE=''

parse_runtime_args() {
  CLI_BOARD=''
  CLI_PORT=''
  CLI_MONITOR_CONFIG=''
  CLI_ARDUINO_IDE=''
  CLI_CLEAN_BUILD=0
  CLI_BUILD=0
  CLI_VERBOSE=0
  CLI_QUIET=0
  CLI_UNITS='auto'
  CLI_ARGS=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      board=*)
        CLI_BOARD="${1#board=}"
        ;;
      port=*)
        CLI_PORT="${1#port=}"
        ;;
      monitor_config=*)
        CLI_MONITOR_CONFIG="${1#monitor_config=}"
        ;;
      arduino_ide=*)
        CLI_ARDUINO_IDE="${1#arduino_ide=}"
        ;;
      --board)
        [ "$#" -ge 2 ] || die "--board requires a value"
        CLI_BOARD="$2"
        shift
        ;;
      --port)
        [ "$#" -ge 2 ] || die "--port requires a value"
        CLI_PORT="$2"
        shift
        ;;
      --monitor-config)
        [ "$#" -ge 2 ] || die "--monitor-config requires a value"
        CLI_MONITOR_CONFIG="$2"
        shift
        ;;
      --arduino-ide)
        [ "$#" -ge 2 ] || die "--arduino-ide requires a value"
        CLI_ARDUINO_IDE="$2"
        shift
        ;;
      --clean-build)
        CLI_CLEAN_BUILD=1
        ;;
      --build)
        CLI_BUILD=1
        ;;
      --units=*)
        CLI_UNITS="${1#--units=}"
        ;;
      --units)
        [ "$#" -ge 2 ] || die "--units requires a value"
        CLI_UNITS="$2"
        shift
        ;;
      -v|--verbose)
        CLI_VERBOSE=1
        ;;
      -q|--quiet)
        CLI_QUIET=1
        ;;
      *)
        CLI_ARGS+=("$1")
        ;;
    esac
    shift
  done

  case "$CLI_UNITS" in
    auto|b|kb|mb)
      ;;
    *)
      die "--units must be one of: b, kb, mb, auto"
      ;;
  esac
}

parse_generate_args() {
  GEN_SRC_DIR=''
  GEN_OUT_BASE=''

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --src)
        [ "$#" -ge 2 ] || die "--src requires a value"
        GEN_SRC_DIR="$2"
        shift
        ;;
      --out)
        [ "$#" -ge 2 ] || die "--out requires a value"
        GEN_OUT_BASE="$2"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown generator option: $1"
        ;;
    esac
    shift
  done
}

find_python3() {
  local py
  py="$(command -v python3 2>/dev/null || true)"
  [ -n "$py" ] || die "python3 is required"
  printf '%s' "$py"
}

run_texture_generator() {
  local project_dir="$1"
  local src_dir="${2:-textures}"
  local out_base="${3:-TexturesGenerated}"
  local py

  py="$(find_python3)"
  "$py" "$SCRIPT_DIR/generate_textures.py" \
    --project-dir "$project_dir" \
    --src-dir "$src_dir" \
    --out-base "$out_base"
}

run_sample_generator() {
  local project_dir="$1"
  local src_dir="${2:-samples}"
  local out_base="${3:-SamplesGenerated}"
  local py

  py="$(find_python3)"
  "$py" "$SCRIPT_DIR/generate_samples.py" \
    --project-dir "$project_dir" \
    --src-dir "$src_dir" \
    --out-base "$out_base"
}

run_generate_command() {
  local action="$1"
  local src_dir
  local out_base

  case "$action" in
    gentextures)
      src_dir="${GEN_SRC_DIR:-textures}"
      out_base="${GEN_OUT_BASE:-TexturesGenerated}"
      run_texture_generator "$PWD" "$src_dir" "$out_base"
      ;;
    gensamples)
      src_dir="${GEN_SRC_DIR:-samples}"
      out_base="${GEN_OUT_BASE:-SamplesGenerated}"
      run_sample_generator "$PWD" "$src_dir" "$out_base"
      ;;
    *)
      die "unsupported generator action '$action'"
      ;;
  esac
}

resolve_selected_board() {
  load_project_context
  if [ -n "$CLI_BOARD" ]; then
    array_contains "$CLI_BOARD" "${PROJECT_BOARDS[@]}" || \
      die "board '$CLI_BOARD' is not enabled for this project. Available: ${PROJECT_BOARDS[*]}"
    printf '%s' "$CLI_BOARD"
