find_size_tool() {
  local board="$1"
  local candidate=''

  case "$board" in
    esp32)
      candidate="$(command -v xtensa-esp-elf-size 2>/dev/null || true)"
      if [ -n "$candidate" ]; then
        printf '%s' "$candidate"
        return
      fi
      candidate="$HOME/.arduino15/packages/esp32/tools/esp-x32/2511/bin/xtensa-esp-elf-size"
      [ -x "$candidate" ] || die "xtensa-esp-elf-size not found for board '$board'"
      printf '%s' "$candidate"
      ;;
    *)
      candidate="$(command -v size 2>/dev/null || true)"
      [ -n "$candidate" ] || die "'size' tool not found for board '$board'"
      printf '%s' "$candidate"
      ;;
  esac
}

