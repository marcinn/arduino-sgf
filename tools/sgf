run_elfinfo() {
  local board="$1"
  local build_dir="$PWD/build/$board"
  local elf_path="$build_dir/$ENTRYPOINT.elf"
  local map_path="$build_dir/$ENTRYPOINT.map"
  local bin_path="$build_dir/$ENTRYPOINT.bin"
  local size_tool
  local flash_limit
  local dram_limit
  local static_dram_limit

  [ -f "$elf_path" ] || die "ELF not found: $elf_path"
  [ -f "$map_path" ] || die "MAP not found: $map_path"
  [ -f "$bin_path" ] || die "BIN not found: $bin_path"

  size_tool="$(find_size_tool "$board")"
  flash_limit="$(board_flash_limit_bytes "$board")"
  dram_limit="$(board_dram_limit_bytes "$board")"
  static_dram_limit="$(board_static_dram_limit_bytes "$board")"
  command -v python3 >/dev/null 2>&1 || die "python3 is required for elfinfo"

  python3 - "$size_tool" "$build_dir" "$ENTRYPOINT" "$elf_path" "$map_path" "$bin_path" "$CLI_UNITS" "$flash_limit" "$dram_limit" "$static_dram_limit" <<'PY'
import os
import re
import subprocess
import sys
from collections import defaultdict

size_tool, build_dir, entrypoint, elf_path, map_path, bin_path, units, flash_limit, dram_limit, static_dram_limit = sys.argv[1:]
flash_limit = int(flash_limit)
dram_limit = int(dram_limit)
static_dram_limit = int(static_dram_limit)

def stat_size(path):
    return os.stat(path).st_size

def fmt_bytes(value):
    if units == "b":
        return f"{value} B"
    if units == "kb":
        return f"{value / 1024.0:.1f} KB"
    if units == "mb":
        return f"{value / (1024.0 * 1024.0):.2f} MB"
    if value >= 1024 * 1024:
        return f"{value / (1024.0 * 1024.0):.2f} MB"
    if value >= 1024:
        return f"{value / 1024.0:.1f} KB"
    return f"{value} B"

def fmt_percent(used, limit):
    if limit <= 0:
        return "n/a"
    return f"{(used * 100.0) / limit:.1f}%"

def fmt_usage(used, limit):
    if limit <= 0:
        return f"{fmt_bytes(used)} / n/a"
    return f"{fmt_bytes(used)} / {fmt_bytes(limit)} ({fmt_percent(used, limit)})"

def progress_bar(used, limit, width=24):
    if limit <= 0:
        return "[" + ("?" * width) + "]"
    ratio = used / float(limit)
    if ratio < 0:
        ratio = 0.0
    filled = int(width * min(ratio, 1.0) + 0.5)
    if filled > width:
        filled = width
    return "[" + ("#" * filled) + ("." * (width - filled)) + "]"

def parse_top_sections(map_path):
    wanted = {"dram0.data", "dram0.bss", "flash.rodata", "flash.text", "iram0.text"}
    out = {}
    sec_re = re.compile(r"^\.(dram0\.data|dram0\.bss|flash\.rodata|flash\.text|iram0\.text)\s+0x[0-9a-fA-F]+\s+0x([0-9a-fA-F]+)")
    with open(map_path, "r", errors="ignore") as fh:
        for line in fh:
            m = sec_re.match(line)
            if m:
                out[m.group(1)] = int(m.group(2), 16)
    return out

def group_of_obj(path):
    if "/build/esp32/sketch/" in path:
        return "sketch"
    if "/build/esp32/libraries/SGF/SGF/" in path:
        return "SGF"
    if "/build/esp32/libraries/sgf-esp32/SGF/" in path:
        return "sgf-esp32"
    if "/build/esp32/libraries/sgf-hardware-presets/" in path:
        return "sgf-hardware-presets"
    if "/build/esp32/libraries/" in path:
        return "other-libraries"
    if "/build/esp32/core/" in path:
        return "arduino-core"
    return "toolchain-idf"

def parse_linked_dram_by_group(map_path):
    current = None
    sec_re = re.compile(r"^\.(dram0\.data|dram0\.bss)\s+")
    any_top_re = re.compile(r"^\.([A-Za-z0-9_\.]+)\s+")
    line_re = re.compile(r"^\s+\.[^\s]*\s+0x[0-9a-fA-F]+\s+0x([0-9a-fA-F]+)\s+(.+)$")
    agg = defaultdict(int)
    with open(map_path, "r", errors="ignore") as fh:
        for line in fh:
            m = sec_re.match(line)
            if m:
                current = m.group(1)
                continue
            m = any_top_re.match(line)
            if m and not sec_re.match(line):
                current = None
            if current is None:
                continue
            m = line_re.match(line)
            if not m:
                continue
            size = int(m.group(1), 16)
            obj = m.group(2).strip()
            if size == 0 or obj.startswith("*fill*") or obj.startswith("0x") or obj.startswith("ALIGN"):
                continue
            agg[(group_of_obj(obj), current)] += size
    return agg

def parse_linked_dram_by_object(map_path):
    current = None
    sec_re = re.compile(r"^\.(dram0\.data|dram0\.bss)\s+")
    any_top_re = re.compile(r"^\.([A-Za-z0-9_\.]+)\s+")
    line_re = re.compile(r"^\s+\.[^\s]*\s+0x[0-9a-fA-F]+\s+0x([0-9a-fA-F]+)\s+(.+)$")
    agg = defaultdict(int)
    with open(map_path, "r", errors="ignore") as fh:
        for line in fh:
            m = sec_re.match(line)
            if m:
                current = m.group(1)
                continue
            m = any_top_re.match(line)
            if m and not sec_re.match(line):
                current = None
            if current is None:
                continue
            m = line_re.match(line)
            if not m:
                continue
            size = int(m.group(1), 16)
            obj = m.group(2).strip()
            if size == 0 or obj.startswith("*fill*") or obj.startswith("0x") or obj.startswith("ALIGN"):
                continue
            agg[obj] += size
    return agg

def collect_object_sizes(size_tool, root):
    groups = {
        "sketch": os.path.join(root, "sketch"),
        "SGF": os.path.join(root, "libraries", "SGF", "SGF"),
        "sgf-esp32": os.path.join(root, "libraries", "sgf-esp32", "SGF"),
        "sgf-hardware-presets": os.path.join(root, "libraries", "sgf-hardware-presets"),
    }
    out = {}
    for name, base in groups.items():
        files = []
        if not os.path.isdir(base):
            continue
        for dirpath, _, filenames in os.walk(base):
            for fn in filenames:
                if fn.endswith(".o"):
                    files.append(os.path.join(dirpath, fn))
        files.sort()
        if not files:
            continue
        proc = subprocess.check_output([size_tool, *files], text=True)
        totals = [0, 0, 0, 0]
        for line in proc.splitlines()[1:]:
            parts = line.split()
            if len(parts) >= 5 and parts[0].isdigit():
                vals = list(map(int, parts[:4]))
                for i, v in enumerate(vals):
                    totals[i] += v
        out[name] = totals
    return out

sections = parse_top_sections(map_path)
linked_dram = parse_linked_dram_by_group(map_path)
linked_dram_objects = parse_linked_dram_by_object(map_path)
object_sizes = collect_object_sizes(size_tool, build_dir)
flash_used = sections.get("flash.text", 0) + sections.get("flash.rodata", 0)
dram_used = sections.get("dram0.data", 0) + sections.get("dram0.bss", 0)
static_dram_used = dram_used

print("[ELFINFO] files")
print(f"  elf: {elf_path} ({fmt_bytes(stat_size(elf_path))})")
print(f"  bin: {bin_path} ({fmt_bytes(stat_size(bin_path))})")
print(f"  map: {map_path} ({fmt_bytes(stat_size(map_path))})")

print("[ELFINFO] sections")
for key in ("flash.text", "flash.rodata", "iram0.text", "dram0.data", "dram0.bss"):
    value = sections.get(key, 0)
    print(f"  {key}: {fmt_bytes(value)}")

print("[ELFINFO] linked dram by group")
print("  exact static DRAM contribution after link")
groups = ("sketch", "SGF", "sgf-esp32", "sgf-hardware-presets", "other-libraries", "arduino-core", "toolchain-idf")
for group in groups:
    data = linked_dram.get((group, "dram0.data"), 0)
    bss = linked_dram.get((group, "dram0.bss"), 0)
    total = data + bss
    if total == 0:
        continue
    print(f"  {group}: init-data={fmt_bytes(data)} zero-bss={fmt_bytes(bss)} static-total={fmt_bytes(total)}")

print("[ELFINFO] compiled object sizes (approx)")
print("  compile-time object sums; useful for code-size direction, not exact post-link usage")
for group in ("sketch", "SGF", "sgf-esp32", "sgf-hardware-presets"):
    vals = object_sizes.get(group)
    if not vals:
        continue
    text, data, bss, dec = vals
    print(f"  {group}: code={fmt_bytes(text)} init-data={fmt_bytes(data)} zero-bss={fmt_bytes(bss)} object-total={fmt_bytes(dec)}")

print("[ELFINFO] board limits")
if flash_limit > 0:
    print(f"  flash usage: {fmt_usage(flash_used, flash_limit)}")
if dram_limit > 0:
    print(f"  dram usage: {fmt_usage(dram_used, dram_limit)}")
if static_dram_limit > 0:
    print(f"  static dram link segment: {fmt_usage(static_dram_used, static_dram_limit)}")

print("[ELFINFO] usage bars")
if flash_limit > 0:
    print(f"  flash {progress_bar(flash_used, flash_limit)} {fmt_percent(flash_used, flash_limit)}")
if dram_limit > 0:
    print(f"  dram  {progress_bar(dram_used, dram_limit)} {fmt_percent(dram_used, dram_limit)}")
if static_dram_limit > 0:
    print(f"  sdram {progress_bar(static_dram_used, static_dram_limit)} {fmt_percent(static_dram_used, static_dram_limit)}")

print("[ELFINFO] top static DRAM objects")
top_objects = sorted(linked_dram_objects.items(), key=lambda kv: kv[1], reverse=True)[:12]
for obj, size in top_objects:
    label = obj
    if "/build/esp32/sketch/" in obj:
        label = "sketch/" + os.path.basename(obj)
    elif "/build/esp32/libraries/SGF/SGF/" in obj:
        label = "SGF/" + os.path.basename(obj)
    elif "/build/esp32/libraries/sgf-esp32/SGF/" in obj:
        label = "sgf-esp32/" + os.path.basename(obj)
    elif "/build/esp32/core/" in obj:
        label = "core/" + os.path.basename(obj)
    else:
        label = os.path.basename(obj)
    print(f"  {label}: {fmt_bytes(size)}")
PY
}

run_upload() {
  local board="$1"
  local fqbn="$2"
  local board_options="$3"
  local port="$4"
  local build_dir="$PWD/build/$board"
  local stage_dir="$PWD/build-stage/$board/$SKETCH_NAME"
  local build_elf="$build_dir/$ENTRYPOINT.elf"
  local build_bin="$build_dir/$ENTRYPOINT.bin"
  local arduino_cli
  local upload_args=()

  [ -n "$port" ] || die "port is required for upload/flash"
  [ -d "$build_dir" ] || die "build directory not found: $build_dir (run '$SCRIPT_NAME build board=$board' or use '$SCRIPT_NAME flash')"
  [ -d "$stage_dir" ] || die "staged sketch not found: $stage_dir (run '$SCRIPT_NAME build board=$board' or use '$SCRIPT_NAME flash')"
  [ -f "$build_elf" ] || die "ELF not found: $build_elf (run '$SCRIPT_NAME build board=$board' or use '$SCRIPT_NAME flash')"
  [ -f "$build_bin" ] || die "BIN not found: $build_bin (run '$SCRIPT_NAME build board=$board' or use '$SCRIPT_NAME flash')"

  arduino_cli="$(find_arduino_cli)"

  upload_args+=(
    upload
    --fqbn "$fqbn"
    --build-path "$build_dir"
    --port "$port"
  )

  if [ "$CLI_VERBOSE" -eq 1 ]; then
    upload_args+=(--verbose)
  fi

  if [ -n "$board_options" ]; then
    upload_args+=(--board-options "$board_options")
  fi

  if [ "${#CLI_ARGS[@]}" -gt 0 ]; then
    upload_args+=("${CLI_ARGS[@]}")
  fi

  upload_args+=("$stage_dir")
  if [ "$CLI_QUIET" -eq 1 ] && [ "$CLI_VERBOSE" -eq 0 ]; then
    local output
    local status
    set +e
    output="$("$arduino_cli" "${upload_args[@]}" 2>&1)"
    status=$?
    set -e
    if [ "$status" -ne 0 ]; then
      printf '%s\n' "$output"
    fi
    return "$status"
  fi

  "$arduino_cli" "${upload_args[@]}"
}

